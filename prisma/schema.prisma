generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  password  String
  role      String    @default("user")
  bio       String    @default("")
  avatarUrl          String    @default("")
  stripeCustomerId   String?   @unique
  subscriptionId     String?   @unique
  subscriptionStatus String    @default("none")
  priceId            String?
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages            Message[]
  copyTradingAccounts CopyTradingAccount[]
  license             License?
}

model License {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  key       String   @unique
  status    String   @default("active")
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bindings  LicenseBinding[]
  logs      LicenseValidationLog[]
}

model LicenseBinding {
  id              String   @id @default(cuid())
  licenseId       String
  license         License  @relation(fields: [licenseId], references: [id])
  mt5Account      String
  accountType     String
  brokerServer    String   @default("")
  firstSeenAt     DateTime @default(now())
  lastValidatedAt DateTime @default(now())
  lastIp          String   @default("")

  @@unique([licenseId, mt5Account])
}

model LicenseValidationLog {
  id           String   @id @default(cuid())
  licenseId    String?
  license      License? @relation(fields: [licenseId], references: [id])
  keyAttempted String
  mt5Account   String   @default("")
  ipAddress    String   @default("")
  userAgent    String   @default("")
  result       String
  createdAt    DateTime @default(now())

  @@index([licenseId, createdAt])
  @@index([createdAt])
}

model CopyTradingAccount {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id])
  metacopierAccountId   String?   @unique
  metacopierId          String?   @unique
  metacopierRiskLimitId String?
  brokerServer          String
  loginNumber           String
  status                String    @default("pending")
  riskMultiplier        Float     @default(1.0)
  dailyRiskLimit        Float     @default(10)
  alias                 String    @default("")
  balance               Float?
  equity                Float?
  errorMessage          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  icon      String    @default("")
  order     Int       @default(0)
  channels  Channel[]
  createdAt DateTime  @default(now())
}

model Channel {
  id          String    @id @default(cuid())
  name        String
  description String    @default("")
  isPremium   Boolean   @default(false)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  order       Int       @default(0)
  messages    Message[]
  createdAt   DateTime  @default(now())

  @@unique([categoryId, name])
}

model Message {
  id           String    @id @default(cuid())
  content      String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  adminDeleted Boolean   @default(false)
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  channelId    String
  channel      Channel   @relation(fields: [channelId], references: [id])
}
